---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CollectionCta from '../components/CollectionCta.astro';
import { createBreadcrumbSchema } from '../lib/seo';

const title = 'Thank You | SGV Turf';
const description =
  'Thank-you page for SGV Turf project-brief submissions with next-step links into city guides, contractor profiles, and rebate guidance.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Thanks' },
];

const structuredData = createBreadcrumbSchema(
  [
    { name: 'Home', path: '/' },
    { name: 'Thanks', path: '/thanks/' },
  ],
  Astro.site,
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="/thanks/"
  ogTitle="Thank You | SGV Turf"
  ogDescription="Confirmation page for SGV Turf project-brief submissions with clear next-step planning guidance."
  structuredData={structuredData}
  noindex={true}
>
  <Nav />
  <Breadcrumbs items={breadcrumbs} />
  <main id="main-content">
    <PageHero
      eyebrow="Project Brief Received"
      description="Your project brief is in. SGV Turf can now use it to organize your inquiry while you continue comparing contractor profiles, rebate options, and city-specific planning notes."
      meta={['Project brief received', 'Next-step planning ready', 'City and rebate guidance available']}
      actions={[
        { href: '/contractors/', label: 'Browse Contractor Profiles' },
        { href: '/rebates/', label: 'Review Rebates', variant: 'ghost' },
      ]}
    >
      <span slot="title">
        Thanks for sharing<br />
        <em>your project brief</em>
      </span>
    </PageHero>

    <section class="surface-section surface-section--white">
      <div class="section-shell detail-grid">
        <div class="detail-main">
          <div class="detail-panel">
            <p class="detail-panel__eyebrow">Confirmation</p>
            <h2 class="detail-panel__title">Your brief is on file.</h2>
            <p class="detail-panel__copy">
              SGV Turf has the details you submitted, including your city, project type, and any
              notes you added. Use this as your planning baseline while you refine scope, compare
              approaches, and prepare for contractor conversations.
            </p>
          </div>

          <div class="detail-panel">
            <p class="detail-panel__eyebrow">What Happens Next</p>
            <ul class="detail-list">
              <li>Use your brief as a reference point while comparing contractor profiles and project approaches.</li>
              <li>Review city notes and rebate guidance to sharpen priorities before the first contractor call.</li>
              <li>Bring the same scope, goals, and budget context into every conversation so comparisons stay cleaner.</li>
            </ul>
          </div>
        </div>

        <aside class="detail-sidebar">
          <div class="meta-block">
            <p class="meta-block__title">Keep Browsing</p>
            <div class="list-grid">
              <a href="/cities/">Return to City Guides</a>
              <a href="/contractors/">Browse Contractor Profiles</a>
              <a href="/rebates/">Review Estimated Rebates</a>
            </div>
          </div>

          <div class="meta-block">
            <p class="meta-block__title">Good to Know</p>
            <p class="meta-block__text">
              Rebate amounts remain estimated, and final contractor fit should always be confirmed
              directly before work begins.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <CollectionCta
      eyebrow="Continue Planning"
      title="Use the rest of the site to sharpen the scope."
      text="City pages help with local context, contractor profiles help you compare approaches, and the rebates hub helps frame budget expectations before the first contractor call."
      primaryHref="/cities/"
      primaryLabel="Explore City Guides"
      secondaryHref="/resources/"
      secondaryLabel="Read Resources"
    />
  </main>
  <Footer />
</BaseLayout>
