---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import CollectionCta from '../../components/CollectionCta.astro';
import { cities } from '../../data/cities';
import { contractors } from '../../data/contractors';
import { rebateEntries } from '../../data/rebates';
import type { CityGuide } from '../../data/cities';
import { createBreadcrumbSchema, createServiceSchema } from '../../lib/seo';

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { slug: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props as { city: CityGuide };
const nearbyGuides = cities.filter((entry) => city.nearbyCities.includes(entry.name));
const relatedContractors = contractors
  .filter(
    (entry) =>
      entry.serviceAreas.includes(city.name) ||
      entry.serviceAreas.some((area) => city.nearbyCities.includes(area)),
  )
  .slice(0, 3);
const directRebateMatches = rebateEntries.filter((entry) => entry.coverageCities.includes(city.name));
const nearbyRebateMatches = rebateEntries.filter((entry) =>
  entry.coverageCities.some((coverageCity) => city.nearbyCities.includes(coverageCity)),
);
const planningRebateMatches =
  directRebateMatches.length > 0 ? directRebateMatches : nearbyRebateMatches.slice(0, 2);
const rebateSummary =
  planningRebateMatches.length > 0
    ? `${planningRebateMatches.map((entry) => entry.districtName).join(' and ')} look like the closest SGV-style rebate lanes for ${city.name}. Keep them as planning references only until current utility terms are confirmed.`
    : `Use the rebates hub as an estimate-only planning reference while you confirm which current district or utility program actually applies to ${city.name}.`;
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Cities', href: '/cities/' },
  { label: city.name },
];
const structuredData = [
  createBreadcrumbSchema(
    [
      { name: 'Home', path: '/' },
      { name: 'Cities', path: '/cities/' },
      { name: city.name, path: `/cities/${city.slug}/` },
    ],
    Astro.site,
  ),
  createServiceSchema(
    {
      name: `${city.name} drought-smart landscape planning guide`,
      description: city.metaDescription,
      serviceType: 'Editorial local landscape planning guidance',
      path: `/cities/${city.slug}/`,
      areaServed: city.name,
    },
    Astro.site,
  ),
];
---

<BaseLayout
  title={`${city.name} Landscaping Guide | SGV Turf`}
  description={city.metaDescription}
  canonicalUrl={`/cities/${city.slug}/`}
  ogTitle={`${city.name} Landscaping Guide | SGV Turf`}
  ogDescription={city.intro}
  structuredData={structuredData}
>
  <Nav />
  <Breadcrumbs items={breadcrumbs} />
  <main id="main-content">
    <PageHero
      eyebrow="City Guide"
      description={city.intro}
      meta={[city.nearbyCities.join(' · '), `${city.commonNeeds.length} common project themes`]}
      actions={[
        { href: '/cities/', label: 'Back to Cities', variant: 'ghost' },
        { href: '/rebates/', label: 'Review Estimated Rebates' },
      ]}
    >
      <span slot="title">
        {city.name}<br />
        <em>landscape guide</em>
      </span>
    </PageHero>

    <section class="surface-section surface-section--cream">
      <div class="section-shell detail-grid">
        <div class="detail-main">
          <div class="detail-panel">
            <p class="detail-panel__eyebrow">Overview</p>
            <h2 class="detail-panel__title">{city.headline}</h2>
            <div class="detail-richtext">
              {city.narrative.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </div>

          <div class="detail-panel">
            <p class="detail-panel__eyebrow">Common Landscaping Needs</p>
            <ul class="detail-list">
              {city.commonNeeds.map((need) => (
                <li>{need}</li>
              ))}
            </ul>
          </div>

          <div class="detail-panel">
            <p class="detail-panel__eyebrow">Local Notes</p>
            <ul class="detail-list">
              {city.localNotes.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </div>
        </div>

        <aside class="detail-sidebar">
          <div class="meta-block">
            <p class="meta-block__title">Plan From This City Page</p>
            <div class="list-grid">
              <a href="/contractors/">Compare sample contractor fits</a>
              <a href="/rebates/">Review estimated rebate guidance</a>
              <a href="/#quote">Start the inquiry flow</a>
            </div>
          </div>

          {relatedContractors.length > 0 && (
            <div class="meta-block">
              <p class="meta-block__title">Suggested Contractor Profiles</p>
              <div class="list-grid">
                {relatedContractors.map((entry) => (
                  <a href={`/contractors/${entry.slug}/`}>{entry.name}</a>
                ))}
              </div>
            </div>
          )}

          <div class="meta-block">
            <p class="meta-block__title">Nearby Guides</p>
            <div class="list-grid">
              {nearbyGuides.map((guide) => (
                <a href={`/cities/${guide.slug}/`}>{guide.name}</a>
              ))}
            </div>
          </div>

          <div class="meta-block">
            <p class="meta-block__title">Rebate Planning</p>
            <p class="meta-block__text">{rebateSummary}</p>
            <a class="inline-link meta-block__link" href="/rebates/">
              Review estimated rebates
            </a>
          </div>
        </aside>
      </div>
    </section>

    <CollectionCta
      eyebrow="Next Step"
      title={city.ctaTitle}
      text={city.ctaText}
      primaryHref="/#quote"
      primaryLabel="Start Inquiry Flow"
      secondaryHref="/contractors/"
      secondaryLabel="Compare Profiles"
    />
  </main>
  <Footer />
</BaseLayout>
