---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import CityCard from '../../components/CityCard.astro';
import CollectionCta from '../../components/CollectionCta.astro';
import { cities } from '../../data/cities';
import { createBreadcrumbSchema } from '../../lib/seo';

const title = 'SGV City Guides | SGV Turf';
const description =
  'Explore 12 SGV city guides covering common landscaping needs, drought-smart planning considerations, and practical next steps.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Cities' },
];

const structuredData = createBreadcrumbSchema(
  [
    { name: 'Home', path: '/' },
    { name: 'Cities', path: '/cities/' },
  ],
  Astro.site,
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="/cities/"
  ogTitle="SGV City Guides | Local Context for Water-Wise Yards"
  ogDescription="Compare city-specific SGV landscape planning notes, common lot conditions, and next-step links into contractors, rebates, and inquiry."
  structuredData={structuredData}
>
  <Nav />
  <Breadcrumbs items={breadcrumbs} />
  <main id="main-content">
    <PageHero
      eyebrow="Regional Planning"
      description="Each city guide is designed to give SGV homeowners a grounded local starting point before they compare contractors, priorities, and project scope."
      meta={['12 SGV cities', 'Common needs', 'Useful local context']}
      actions={[
        { href: '/contractors/', label: 'Browse Contractors', variant: 'ghost' },
        { href: '/rebates/', label: 'Review Estimated Rebates' },
      ]}
    >
      <span slot="title">
        SGV city guides for<br />
        <em>drought-smart planning</em>
      </span>
    </PageHero>

    <section class="surface-section surface-section--white">
      <div class="section-shell">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Cities</p>
            <h2 class="section-title">
              Regional context for<br />
              <em>real neighborhood conditions</em>
            </h2>
          </div>
        </div>

        <p class="collection-lede">
          Foothill lots, compact historic blocks, and broader suburban front yards do not need the
          same landscape strategy. These pages help frame those differences before you choose a
          direction.
        </p>

        <div class="city-grid">
          {cities.map((city) => (
            <CityCard city={city} />
          ))}
        </div>
      </div>
    </section>

    <CollectionCta
      eyebrow="Keep Researching"
      title="Use the guides to narrow your project brief."
      text="Once you know what your city context suggests, it becomes much easier to compare contractors and decide whether rebate research belongs in the first phase."
      primaryHref="/contractors/"
      primaryLabel="Compare Contractor Profiles"
      secondaryHref="/rebates/"
      secondaryLabel="Browse Rebate Guidance"
    />
  </main>
  <Footer />
</BaseLayout>
