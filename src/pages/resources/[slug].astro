---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import CollectionCta from '../../components/CollectionCta.astro';
import { cities } from '../../data/cities';
import { rebateEntries } from '../../data/rebates';
import { resources } from '../../data/resources';
import type { ResourceArticle } from '../../data/resources';
import { createArticleSchema, createBreadcrumbSchema } from '../../lib/seo';

export function getStaticPaths() {
  return resources.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props as { article: ResourceArticle };
const relatedArticles = resources.filter((entry) => entry.slug !== article.slug).slice(0, 2);
const relatedCities = cities.filter((city) => article.relatedCitySlugs.includes(city.slug));
const relatedRebateEntries = rebateEntries.filter((entry) => article.relatedRebateSlugs.includes(entry.slug));
const rebateContext =
  relatedRebateEntries.length > 0
    ? `${relatedRebateEntries.map((entry) => entry.districtName).join(' and ')} are useful estimate-only rebate lanes to compare alongside this topic.`
    : 'Use the rebates hub as a planning cross-check if budget framing is part of the project.';
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources/' },
  { label: article.title },
];
const structuredData = [
  createBreadcrumbSchema(
    [
      { name: 'Home', path: '/' },
      { name: 'Resources', path: '/resources/' },
      { name: article.title, path: `/resources/${article.slug}/` },
    ],
    Astro.site,
  ),
  createArticleSchema(
    {
      headline: article.title,
      description: article.metaDescription,
      path: `/resources/${article.slug}/`,
      datePublished: article.publishedAt,
      category: article.category,
      keywords: article.tags,
    },
    Astro.site,
  ),
];
---

<BaseLayout
  title={`${article.title} | SGV Turf`}
  description={article.metaDescription}
  canonicalUrl={`/resources/${article.slug}/`}
  ogTitle={`${article.title} | SGV Turf`}
  ogDescription={article.excerpt}
  ogType="article"
  structuredData={structuredData}
>
  <Nav />
  <Breadcrumbs items={breadcrumbs} />
  <main id="main-content">
    <PageHero
      eyebrow={article.category}
      description={article.excerpt}
      meta={[article.publishedLabel, article.readTime, article.tags.join(' · ')]}
      actions={[
        { href: '/resources/', label: 'Back to Resources', variant: 'ghost' },
        { href: '/rebates/', label: 'Review Estimated Rebates' },
      ]}
    >
      <span slot="title">{article.title}</span>
    </PageHero>

    <section class="surface-section surface-section--white">
      <div class="section-shell article-grid">
        <article class="article-main">
          <div class="article-panel">
            <p class="article-panel__eyebrow">Intro</p>
            <p class="article-panel__copy">{article.intro}</p>
          </div>

          <div class="article-panel">
            <p class="article-panel__eyebrow">Key Takeaways</p>
            <ul class="article-list">
              {article.keyTakeaways.map((takeaway) => (
                <li>{takeaway}</li>
              ))}
            </ul>
          </div>

          <div class="article-prose">
            {article.sections.map((section) => (
              <section class="article-section">
                <h2>{section.heading}</h2>
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
                {section.bullets && (
                  <ul class="article-list">
                    {section.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}
              </section>
            ))}
          </div>
        </article>

        <aside class="article-sidebar">
          {relatedCities.length > 0 && (
            <div class="meta-block">
              <p class="meta-block__title">Related City Guides</p>
              <div class="list-grid">
                {relatedCities.map((city) => (
                  <a href={`/cities/${city.slug}/`}>{city.name}</a>
                ))}
              </div>
            </div>
          )}

          <div class="meta-block">
            <p class="meta-block__title">Article Topics</p>
            <ul class="meta-list">
              {article.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </div>

          <div class="meta-block">
            <p class="meta-block__title">Related Rebate Planning</p>
            <p class="meta-block__text">{rebateContext}</p>
            <a class="inline-link meta-block__link" href="/rebates/">
              Review estimated rebates
            </a>
          </div>
        </aside>
      </div>
    </section>

    <section class="surface-section surface-section--cream">
      <div class="section-shell">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">More Reading</p>
            <h2 class="section-title">
              Continue with another<br />
              <em>planning article</em>
            </h2>
          </div>
        </div>

        <div class="resource-list">
          {relatedArticles.map((entry) => (
            <ResourceCard article={entry} featured={false} />
          ))}
        </div>
      </div>
    </section>

    <CollectionCta
      eyebrow="Next Step"
      title={article.ctaTitle}
      text={article.ctaText}
      primaryHref="/resources/"
      primaryLabel="Browse All Resources"
      secondaryHref="/rebates/"
      secondaryLabel="Review Rebate Guidance"
    />
  </main>
  <Footer />
</BaseLayout>
