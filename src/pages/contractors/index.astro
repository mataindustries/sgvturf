---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import ContractorCard from '../../components/ContractorCard.astro';
import ContractorPricing from '../../components/ContractorPricing.astro';
import { contractors } from '../../data/contractors';
import { createBreadcrumbSchema } from '../../lib/seo';

const title = 'SGV Contractor Profiles | SGV Turf';
const description =
  'Browse SGV contractor profiles for drought-smart landscaping, turf removal, irrigation upgrades, and low-water front yard planning.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contractors' },
];

const structuredData = createBreadcrumbSchema(
  [
    { name: 'Home', path: '/' },
    { name: 'Contractors', path: '/contractors/' },
  ],
  Astro.site,
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="/contractors/"
  ogTitle="SGV Contractor Profiles | SGV Turf"
  ogDescription="Review SGV contractor profiles for different yard types, specialties, and planning fits."
  structuredData={structuredData}
>
  <Nav />
  <Breadcrumbs items={breadcrumbs} />
  <main id="main-content">
    <PageHero
      eyebrow="Contractor Profiles"
      description="These editorial profiles are designed to help you compare specialties, service areas, and project fit with a clearer sense of what to look for."
      meta={['6 contractor profiles', 'Premium editorial framing', 'Organized by specialty']}
      actions={[
        { href: '/cities/', label: 'Explore City Guides', variant: 'ghost' },
        { href: '/resources/', label: 'Read Resources' },
      ]}
    >
      <span slot="title">
        Compare <em>contractor fits</em><br />
        before you shortlist.
      </span>
    </PageHero>

    <section class="surface-section surface-section--white">
      <div class="section-shell">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Profile Collection</p>
            <h2 class="section-title">
              Different specialties for<br />
              <em>different SGV yards</em>
            </h2>
          </div>
        </div>

        <p class="collection-lede">
          Use these profiles as reference points: design-forward studios for Pasadena-adjacent
          lots, practical planners for warm suburban yards, and foothill-aware approaches for more
          complex sites.
        </p>

        <div class="contractor-grid">
          {contractors.map((contractor) => (
            <ContractorCard contractor={contractor} />
          ))}
        </div>
      </div>
    </section>
    <ContractorPricing
      sectionId="founder-offer"
      primaryHref="/#quote"
      primaryLabel="Apply for Founder Spot"
      bottomPrimaryHref="/#quote"
      bottomPrimaryLabel="Request Founder Details"
    />
  </main>
  <Footer />
</BaseLayout>
