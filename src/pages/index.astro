---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SearchStrip from '../components/SearchStrip.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FeaturedContractors from '../components/FeaturedContractors.astro';
import CitiesStrip from '../components/CitiesStrip.astro';
import LeadForm from '../components/LeadForm.astro';
import EditorialGrid from '../components/EditorialGrid.astro';
import ContractorPricing from '../components/ContractorPricing.astro';
import Footer from '../components/Footer.astro';
import { createOrganizationSchema, createServiceSchema, createWebsiteSchema } from '../lib/seo';
import { defaultDescription, defaultTitle } from '../data/site';

const title = defaultTitle;
const description = defaultDescription;

const structuredData = [
  createOrganizationSchema(Astro.site),
  createWebsiteSchema(Astro.site),
  createServiceSchema(
    {
      name: 'SGV drought-smart landscape planning guidance',
      description,
      serviceType:
        'Editorial landscape planning guidance, sample contractor positioning, and estimated rebate research',
      path: '/',
      areaServed: 'San Gabriel Valley',
      areaType: 'AdministrativeArea',
    },
    Astro.site,
  ),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="/"
  ogTitle="SGV Turf | City Guides, Rebates, and Water-Wise Project Planning"
  ogDescription="Browse SGV city guides, sample contractor profiles, estimated rebate planning, and editorial landscape resources for lower-water yard projects."
  structuredData={structuredData}
>
  <Nav />
  <main id="main-content">
    <Hero />
    <SearchStrip />
    <HowItWorks />
    <FeaturedContractors />
    <CitiesStrip />
    <LeadForm />
    <EditorialGrid />
    <ContractorPricing />
  </main>
  <Footer />
</BaseLayout>
