---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SearchStrip from '../components/SearchStrip.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FeaturedContractors from '../components/FeaturedContractors.astro';
import CitiesStrip from '../components/CitiesStrip.astro';
import LeadForm from '../components/LeadForm.astro';
import EditorialGrid from '../components/EditorialGrid.astro';
import ContractorPricing from '../components/ContractorPricing.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
