---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = 'Next Step',
  title,
  text,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="surface-section surface-section--white">
  <div class="section-shell">
    <div class="collection-cta">
      <div>
        <p class="section-eyebrow">{eyebrow}</p>
        <h2 class="collection-cta__title">{title}</h2>
        <p class="collection-cta__text">{text}</p>
      </div>

      <div class="collection-cta__actions">
        <a class="button button--primary" href={primaryHref}>{primaryLabel}</a>
        {secondaryHref && secondaryLabel && (
          <a class="button button--ghost" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>
