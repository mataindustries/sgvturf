---
import { contractors } from '../data/contractors';
import ContractorCard from './ContractorCard.astro';

const featuredContractors = contractors.filter((contractor) => contractor.featured).slice(0, 3);
---

<section class="surface-section surface-section--white" id="directory">
  <div class="section-shell">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Featured Profiles</p>
        <h2 class="section-title">
          Contractor profiles<br />
          for <em>smart SGV shortlists</em>
        </h2>
      </div>

      <a class="button button--ghost section-header__action" href="/contractors/">Browse All 6</a>
    </div>

    <div class="contractor-grid">
      {featuredContractors.map((contractor) => (
        <ContractorCard contractor={contractor} />
      ))}
    </div>
  </div>
</section>
