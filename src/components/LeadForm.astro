---
import { cityOptions } from '../data/cities';
import { lawnSizes, leadFormProjectTypes as projectTypes } from '../data/site';

const benefits = [
  'Reference city-specific planning notes before you talk to a pro',
  'Compare contractor specialties and service areas in one place',
  'Use editorial resources to shape your project brief',
  'Prototype inquiry form retained for future backend wiring',
  'No sign-in required to browse the seeded directory content',
];
---

<section class="lead-section" id="quote">
  <div class="section-shell lead-section__inner">
    <div class="lead-section__copy">
      <p class="section-eyebrow section-eyebrow--soft">Free Project Quotes</p>
      <h2 class="lead-section__title">
        Capture your project brief.<br />
        Use it to <em>compare smarter.</em>
      </h2>
      <p class="lead-section__description">
        This form currently serves as a prototype placeholder while the marketplace workflow is
        still being built out. For now, use it alongside the new city guides, sample contractor
        profiles, and editorial resources to organize your project scope.
      </p>

      <ul class="benefit-list">
        {benefits.map((benefit) => (
          <li>{benefit}</li>
        ))}
      </ul>
    </div>

    <form class="lead-form">
      <h3 class="lead-form__title">Outline Your Project</h3>
      <p class="lead-form__subtitle">Prototype form · Content-first build</p>

      <div class="form-row">
        <label class="field">
          <span class="field__label">First Name</span>
          <input class="field__control" type="text" name="firstName" placeholder="Maria" />
        </label>

        <label class="field">
          <span class="field__label">Last Name</span>
          <input class="field__control" type="text" name="lastName" placeholder="Gonzalez" />
        </label>
      </div>

      <label class="field">
        <span class="field__label">Email</span>
        <input class="field__control" type="email" name="email" placeholder="maria@email.com" />
      </label>

      <label class="field">
        <span class="field__label">Phone</span>
        <input class="field__control" type="tel" name="phone" placeholder="(626) 555-0100" />
      </label>

      <div class="form-row">
        <label class="field">
          <span class="field__label">City</span>
          <select class="field__control" name="city">
            <option value="">Select city</option>
            {cityOptions.map((city) => (
              <option>{city}</option>
            ))}
          </select>
        </label>

        <label class="field">
          <span class="field__label">Lawn Size (sq ft)</span>
          <select class="field__control" name="lawnSize">
            {lawnSizes.map((size) => (
              <option>{size}</option>
            ))}
          </select>
        </label>
      </div>

      <label class="field">
        <span class="field__label">Project Type</span>
        <select class="field__control" name="projectType">
          {projectTypes.map((projectType) => (
            <option>{projectType}</option>
          ))}
        </select>
      </label>

      <label class="field">
        <span class="field__label">Tell us more (optional)</span>
        <textarea
          class="field__control field__control--textarea"
          name="details"
          placeholder="Any details about your property, style preferences, or timeline."
        ></textarea>
      </label>

      <button class="button button--primary button--submit" type="submit">
        Save Prototype Inquiry
      </button>
      <p class="lead-form__note">Not yet connected to live submissions or contractor routing.</p>
    </form>
  </div>
</section>
