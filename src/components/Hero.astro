---
import { cities } from '../data/cities';
import { contractors } from '../data/contractors';
import { rebateEntries } from '../data/rebates';
import { resources } from '../data/resources';

const stats = [
  { value: `${contractors.length}`, label: 'Contractor Profiles' },
  { value: `${cities.length}`, label: 'City Guides' },
  { value: `${rebateEntries.length}`, label: 'Rebate Lanes' },
  { value: `${resources.length}`, label: 'Editorial Reads' },
];
---

<section class="hero" id="top">
  <div class="hero__media" aria-hidden="true">
    <img
      class="hero__image"
      src="/img/sgv-turf-drought-tolerant-front-yard-san-gabriel-valley.jpg"
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__wash"></div>
  </div>

  <div class="section-shell hero__grid">
    <div class="hero__copy">
      <div class="hero__eyebrow">San Gabriel Valley front-yard planning</div>
      <h1 class="hero__title">Ditch the lawn. Build a better SGV yard.</h1>
      <p class="hero__lede">
        Find drought-smart landscape ideas, local contractor placement, and rebate guidance for
        front-yard projects across the San Gabriel Valley.
      </p>

      <div class="hero__actions">
        <a class="button button--primary" href="/#quote">Start Your Project Brief</a>
      </div>

      <div class="hero__stats" aria-label="SGV Turf highlights">
        {stats.map((stat) => (
          <div class="hero-stat">
            <div class="hero-stat__value">{stat.value}</div>
            <div class="hero-stat__label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
