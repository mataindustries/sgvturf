---
import { cityOptions } from '../data/cities';
import { searchServices } from '../data/site';

const cities = ['City', ...cityOptions];
---

<section class="search-strip" id="find" aria-labelledby="find-pro-label">
  <div class="section-shell search-strip__inner">
    <div class="search-strip__copy">
      <p class="search-strip__label" id="find-pro-label">Quick Routing</p>
      <p class="search-strip__note">Use this as a shortcut into the sample contractor directory.</p>
    </div>

    <form class="search-strip__form" action="/contractors/" method="get">
      <select aria-label="Service type" name="service">
        {searchServices.map((service) => (
          <option value={service}>{service}</option>
        ))}
      </select>

      <select aria-label="City" name="city">
        {cities.map((city) => (
          <option value={city}>{city}</option>
        ))}
      </select>

      <input
        type="text"
        name="notes"
        placeholder="Project description (optional)"
        aria-label="Project description"
      />
      <button class="button button--search" type="submit">Browse Profiles</button>
    </form>
  </div>
</section>
