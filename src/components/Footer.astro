---
import { footerColumns, footerMetaLinks, siteTagline } from '../data/site';

const year = new Date().getUTCFullYear();
---

<footer class="site-footer">
  <div class="section-shell">
    <div class="site-footer__grid">
      <div class="site-footer__intro">
        <a class="brand-mark brand-mark--footer" href="/">SGV<span>Turf</span></a>
        <p class="site-footer__tagline">{siteTagline}</p>
        <p class="site-footer__note">
          Use SGV Turf to compare project approaches, contractor profiles, and rebate context, then
          confirm the final fit directly with your selected contractor and local program.
        </p>
        <div class="site-footer__meta-links">
          {footerMetaLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>

      {footerColumns.map((column) => (
        <div>
          <p class="site-footer__title">{column.title}</p>
          <ul class="site-footer__links">
            {column.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">© {year} SGV Turf</p>
      <p class="site-footer__copy">Editorial planning guidance for water-wise SGV landscapes.</p>
    </div>
  </div>
</footer>
