---
import { footerColumns } from '../data/site';

const year = new Date().getUTCFullYear();
---

<footer class="site-footer">
  <div class="section-shell">
    <div class="site-footer__grid">
      <div class="site-footer__intro">
        <a class="brand-mark brand-mark--footer" href="/">SGV<span>Turf</span></a>
        <p class="site-footer__tagline">
          A regional editorial prototype for SGV homeowners exploring water-wise landscaping, turf
          replacement, and drought-smart front yard planning.
        </p>
      </div>

      {footerColumns.map((column) => (
        <div>
          <p class="site-footer__title">{column.title}</p>
          <ul class="site-footer__links">
            {column.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">© {year} SGVTurf.com · All rights reserved</p>
      <p class="site-footer__copy">
        Seeded with sample SGV city guides, contractor profiles, and editorial resources
      </p>
    </div>
  </div>
</footer>
