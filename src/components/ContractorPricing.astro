---
const plans = [
  {
    tier: 'Directory Preview',
    price: 'Free',
    period: 'Concept tier',
    features: [
      'Profile page placeholder',
      '1 specialty category',
      'Service-area highlights',
      'Inquiry form placeholder',
    ],
    emphasis: false,
    cta: 'Reserve Interest',
  },
  {
    tier: 'Editorial Feature',
    price: '$149',
    period: 'future concept',
    features: [
      'Priority placement concept',
      'Up to 5 specialty categories',
      'Featured homepage placement',
      'Expanded project gallery module',
      'Credential fields reserved for later verification',
      'Editorial highlight consideration',
    ],
    emphasis: true,
    cta: 'See Future Packaging',
  },
  {
    tier: 'Lead Workflow',
    price: '$29',
    period: 'future concept',
    features: [
      'Matched inquiry routing placeholder',
      'City and specialty matching logic',
      'Lead review queue reserved for backend work',
      'Flexible participation concept',
      'Acceptance workflow to be defined',
    ],
    emphasis: false,
    cta: 'Review Workflow',
  },
];
---

<section class="surface-section surface-section--white" id="list">
  <div class="section-shell">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">For Contractors</p>
        <h2 class="section-title">
          Preview how SGV Turf could<br />
          <em>package contractor presence</em>
        </h2>
      </div>
    </div>

    <div class="pricing-grid">
      {plans.map((plan) => (
        <article class:list={['pricing-card', plan.emphasis && 'pricing-card--emphasis']}>
          <p class="pricing-card__tier">{plan.tier}</p>
          <div class="pricing-card__price">{plan.price}</div>
          <div class="pricing-card__period">{plan.period}</div>

          <ul class="pricing-card__features">
            {plan.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>

          <a class:list={['button', 'button--pricing', plan.emphasis ? 'button--pricing-dark' : 'button--pricing-light']} href="#quote">
            {plan.cta}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
