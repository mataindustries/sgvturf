---
import FAQItem from './FAQItem.astro';

interface Props {
  sectionId?: string;
  primaryHref?: string;
  primaryLabel?: string;
  bottomPrimaryHref?: string;
  bottomPrimaryLabel?: string;
}

const {
  sectionId = 'list',
  primaryHref = '/contractors/#founder-offer',
  primaryLabel = 'View Founder Offer',
  bottomPrimaryHref = primaryHref,
  bottomPrimaryLabel = primaryLabel,
} = Astro.props;

const included = [
  'Contractor profile page created for your business',
  'Placement on up to 3 relevant SGV city pages',
  'Homepage featured visibility',
  'Logo, specialties, and service areas added for you',
  'Up to 8 project photos',
  'Direct lead forwarding from SGV Turf',
];

const founderTerms = [
  'Live in 72 hours or full refund',
  'No long-term contract',
  'Founder pricing during the opening rollout',
  'Small first-wave rollout',
];

const steps = [
  {
    number: '01',
    title: 'Send your info',
    description:
      'Share your logo, service areas, specialties, contact info, and a few project photos.',
  },
  {
    number: '02',
    title: 'We shape your profile',
    description:
      'Your SGV Turf profile and matching city-page placement are prepared for launch.',
  },
  {
    number: '03',
    title: 'Start receiving inquiries',
    description:
      'Leads from the site are forwarded directly so you can respond fast.',
  },
];

const trustPoints = [
  'Local-first visibility in a niche SGV landscape category',
  'Cleaner presentation than a generic directory listing',
  'City-page placement aligned with where you actually work',
  'Early placement before the directory fills out',
];

const faqs = [
  {
    question: 'What do I need to send?',
    answer:
      'Your logo, business name, service areas, specialties, phone/email, and a few project photos.',
  },
  {
    question: 'How fast can I go live?',
    answer:
      'Most founder profiles can be live within 72 hours once I have your materials.',
  },
  {
    question: 'Is this a long-term contract?',
    answer: 'No. The founder offer is meant to be simple and low-friction.',
  },
  {
    question: 'Do you guarantee leads?',
    answer:
      'No. The founder offer is designed around visibility, placement, and direct inquiry forwarding as the audience grows.',
  },
  {
    question: 'Who is this best for?',
    answer:
      'Contractors doing xeriscape, turf replacement, hardscape, drainage, irrigation, and drought-smart yard work in the San Gabriel Valley.',
  },
];
---

<section class="surface-section surface-section--white" id={sectionId}>
  <div class="section-shell founder-offer">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">FOR CONTRACTORS</p>
        <h2 class="section-title founder-offer__title">Get your SGV Turf founder spot live this week.</h2>
        <p class="collection-lede founder-offer__subhead">
          A polished local placement for SGV landscapers, xeriscape installers, turf pros, and
          hardscape contractors who want early visibility with homeowners planning water-wise
          projects across the San Gabriel Valley.
        </p>
      </div>
    </div>

    <div class="detail-grid founder-offer__grid">
      <div class="detail-main">
        <article class="detail-panel">
          <p class="detail-panel__eyebrow">Offer</p>
          <h3 class="detail-panel__title">Founding Contractor Spot</h3>
          <p class="detail-panel__copy">
            Reserve founder pricing and launch with a polished SGV Turf presence.
          </p>
        </article>

        <article class="detail-panel">
          <p class="detail-panel__eyebrow">What&apos;s Included</p>
          <ul class="detail-list">
            {included.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="detail-panel">
          <p class="detail-panel__eyebrow">Founder Terms</p>
          <ul class="detail-list">
            {founderTerms.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>

      <aside class="detail-sidebar founder-offer__sidebar">
        <article class="pricing-card pricing-card--emphasis founder-offer__card">
          <p class="pricing-card__tier">Founding Contractor Spot</p>
          <div class="pricing-card__price">$99</div>
          <div class="pricing-card__period">Founder offer</div>
          <p class="founder-offer__card-copy">
            Reserve founder pricing and launch with a polished SGV Turf presence.
          </p>

          <ul class="pricing-card__features">
            <li>Profile page built around your business</li>
            <li>Up to 3 relevant city-page placements</li>
            <li>Homepage featured visibility</li>
            <li>Direct lead forwarding from SGV Turf</li>
          </ul>

          <a class="button button--pricing button--pricing-dark" href={primaryHref}>
            {primaryLabel}
          </a>

          <p class="founder-offer__note">
            Best fit for contractors serving the San Gabriel Valley and nearby foothill
            communities.
          </p>
        </article>

        <div class="meta-block">
          <p class="meta-block__title">WHY EARLY CONTRACTORS JOIN</p>
          <ul class="meta-list founder-offer__meta-list">
            {trustPoints.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </aside>
    </div>

    <div class="section-header founder-offer__section-header">
      <div>
        <p class="section-eyebrow">HOW IT WORKS</p>
        <h3 class="section-title founder-offer__section-title">
          Simple founder setup. Clear local visibility.
        </h3>
      </div>
    </div>

    <div class="steps-grid">
      {steps.map((step) => (
        <article class="step-card">
          <div class="step-card__number">{step.number}</div>
          <h4 class="step-card__title">{step.title}</h4>
          <p class="step-card__description">{step.description}</p>
        </article>
      ))}
    </div>

    <article class="detail-panel founder-offer__faq-panel">
      <p class="detail-panel__eyebrow">FAQ</p>
      <h3 class="detail-panel__title">Short answers before you apply for a founder spot.</h3>
      <div class="faq-list">
        {faqs.map((item, index) => (
          <FAQItem question={item.question} answer={item.answer} open={index === 0} />
        ))}
      </div>
    </article>

    <div class="collection-cta founder-offer__cta" id="founder-offer-cta">
      <div>
        <p class="section-eyebrow">Founder Rollout</p>
        <h3 class="collection-cta__title">
          Opening a limited first group of SGV founding contractors.
        </h3>
        <p class="collection-cta__text">
          Start with a short intake and we can shape the right founder setup from there.
        </p>
      </div>

      <div class="collection-cta__actions">
        <a class="button button--primary" href={bottomPrimaryHref}>{bottomPrimaryLabel}</a>
      </div>
    </div>
  </div>
</section>
