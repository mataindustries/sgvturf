---
import { resources } from '../data/resources';
import ResourceCard from './ResourceCard.astro';
---

<section class="surface-section surface-section--cream" id="resources">
  <div class="section-shell">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">The SGV Turf Guide</p>
        <h2 class="section-title">
          Everything you need to<br />
          <em>plan your project</em>
        </h2>
      </div>

      <a class="button button--ghost section-header__action" href="/resources/">All Resources</a>
    </div>

    <div class="editorial-grid">
      {resources.map((article) => (
        <ResourceCard article={article} />
      ))}
    </div>
  </div>
</section>
