---
import { primaryNavLinks } from '../data/site';
---

<nav class="site-nav" aria-label="Primary">
  <div class="section-shell site-nav__inner">
    <a class="brand-mark" href="/" aria-label="SGV Turf home">
      SGV<span>Turf</span>
    </a>

    <div class="site-nav__menu">
      <ul class="site-nav__links">
        {primaryNavLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))}
      </ul>

      <a class="button button--primary button--nav" href="/#list">For Contractors</a>
    </div>
  </div>
</nav>
