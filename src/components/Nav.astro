---
const links = [
  { href: '#find', label: 'Find Contractors' },
  { href: '#resources', label: 'Resources' },
  { href: '#cities', label: 'Cities' },
  { href: '#rebates', label: 'Rebates' },
];
---

<nav class="site-nav" aria-label="Primary">
  <div class="section-shell site-nav__inner">
    <a class="brand-mark" href="#top" aria-label="SGV Turf home">
      SGV<span>Turf</span>
    </a>

    <ul class="site-nav__links">
      {links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))}
      <li>
        <a class="button button--primary button--nav" href="#list">List Your Business</a>
      </li>
    </ul>
  </div>
</nav>
